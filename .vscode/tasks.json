{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Vite dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/app/client" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      }
    },
    {
      "label": "Build client",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/app/client" },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
