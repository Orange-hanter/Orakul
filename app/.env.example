# Master password — used both for login AND for data encryption
# Change before first use. Keep secret.
APP_PASSWORD=change_me_before_use

# JWT signing secret — auto-generated if not set, but set it for persistence across restarts
JWT_SECRET=change_this_to_a_random_string_32_chars

# Server port
PORT=3001

# Telegram bot token (optional)
# Get from @BotFather → /newbot
# If not set, Telegram features are disabled
TELEGRAM_BOT_TOKEN=
