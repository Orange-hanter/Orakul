# Master password — used both for login AND for AES-256-GCM encryption of
# data/store.enc. Treat as the encryption key, not just a login secret.
# Min 12 chars recommended; server logs a warning if shorter.
APP_PASSWORD=change_me_before_use

# JWT signing secret.
#   - In production (NODE_ENV=production) — REQUIRED, server refuses to start.
#   - In development — optional; if absent, a random ephemeral secret is
#     generated, but every restart invalidates all tokens.
JWT_SECRET=change_this_to_a_random_string_32_chars

# Server port (default: 3001)
PORT=3001

# Interface to bind. Default 127.0.0.1 = loopback only (clients reach us
# through nginx on the same host). Override with 0.0.0.0 for Docker, where
# the nginx container talks to this container over docker-compose network.
BIND_HOST=127.0.0.1

# CORS allowlist — comma-separated origins, or unset.
#   - Dev (default): unset → all origins allowed (cors() with no opts).
#   - Prod (default): unset → all origins denied (rely on same-origin nginx).
#   - Override: CORS_ORIGIN=https://orakul.example.com,https://staging.orakul.example.com
CORS_ORIGIN=

# Audit log rotation threshold in bytes (default: 5 MB = 5242880).
AUDIT_MAX_BYTES=

# Telegram bot token (optional — can also be configured via UI on the
# «Данные» tab → ✈️ Telegram-уведомления). Get from @BotFather → /newbot.
# If unset and no token is configured in-app, Telegram features are off.
TELEGRAM_BOT_TOKEN=

# When set to "production", server enforces JWT_SECRET and closes CORS by
# default. Locally — leave empty / unset.
NODE_ENV=
