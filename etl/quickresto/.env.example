# QuickResto ETL — пример конфигурации.
# Скопируй в .env и заполни реальными значениями.
# ⚠️ Не коммить .env в git!

# ── QuickResto API ─────────────────────────────────────────────
# Логин и пароль от QuickResto Back Office
QR_USERNAME=your_qr_login
QR_PASSWORD=your_qr_password

# URL API (обычно https://web.quickresto.ru/platform/online/api)
# или https://eu.quickresto.ru/platform/online/api для EU-зоны
QR_BASE_URL=https://web.quickresto.ru/platform/online/api
QR_LAYER=web

# ── БД (MVP — SQLite, read-only recon тоже его использует) ─────
ETL_DB_BACKEND=sqlite
ETL_SQLITE_PATH=./etl/quickresto/data/etl.db

# ── ETL runtime ────────────────────────────────────────────────
ETL_PAGE_SIZE=100
ETL_REQUEST_DELAY=1.0
ETL_DEBUG=false
ETL_MAX_RETRIES=5
ETL_HTTP_TIMEOUT=30

# ── Venue (если известен ID точки в Orakul) ────────────────────
ETL_DEFAULT_VENUE_ID=
